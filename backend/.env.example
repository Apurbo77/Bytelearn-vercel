################################################################################
# APPLICATION CONFIGURATION
################################################################################
APP_NAME=ByteLearn
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP Development Server Workers (uncomment if needed)
# PHP_CLI_SERVER_WORKERS=4

################################################################################
# SECURITY & ENCRYPTION
################################################################################
BCRYPT_ROUNDS=12

################################################################################
# LOGGING
################################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################################################################
# DATABASE
################################################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bytelearn
DB_USERNAME=root
DB_PASSWORD=

# SQLite alternative (uncomment to use SQLite instead of MySQL)
# DB_CONNECTION=sqlite
# DB_DATABASE=database.sqlite

################################################################################
# SESSION & AUTHENTICATION
################################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

################################################################################
# BROADCAST & REAL-TIME
################################################################################
BROADCAST_CONNECTION=log

################################################################################
# FILE STORAGE
################################################################################
FILESYSTEM_DISK=local

################################################################################
# QUEUE & JOBS
################################################################################
QUEUE_CONNECTION=database
# Alternative: QUEUE_CONNECTION=redis

################################################################################
# CACHING
################################################################################
CACHE_STORE=database
# CACHE_PREFIX=bytelearn_

################################################################################
# REDIS (Optional - for caching, sessions, queues)
################################################################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

################################################################################
# MEMCACHED (Optional - alternative cache driver)
################################################################################
MEMCACHED_HOST=127.0.0.1

################################################################################
# MAIL CONFIGURATION
################################################################################
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=ByteLearn

# For production, configure SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls

################################################################################
# AWS S3 (Optional - for file storage)
################################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

################################################################################
# VITE (Frontend Build Tool)
################################################################################
VITE_APP_NAME=${APP_NAME}

################################################################################
# AI PROVIDERS - CHATBOT & LESSON CHAT
################################################################################

# Google Gemini (Chat & Interactions) - Get key from https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-4b-it
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (Alternative for chat) - Get key from https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (Free & Paid Models - Alternative provider)
# Get key from https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_X_TITLE=ByteLearn

################################################################################
# AI PROVIDERS - QUIZ GENERATION & EVALUATION
################################################################################

# Google Gemini for Quiz (Separate from chatbot for better cost control)
GEMINI_API_KEY_QUIZ=
GEMINI_MODEL_QUIZ=gemini-2.0-flash
GEMINI_BASE_URL_QUIZ=https://generativelanguage.googleapis.com/v1

################################################################################
# AI PROVIDERS - HUGGING FACE (Alternative for QA & Text tasks)
################################################################################
# Get token from https://huggingface.co/settings/tokens
HF_TOKEN=
HF_QA_MODEL=distilbert/distilbert-base-cased-distilled-squad
HF_BASE_URL=https://api-inference.huggingface.co

################################################################################
# NOTIFICATION SETTINGS
################################################################################
NOTIFICATION_ENABLED=true
NOTIFICATION_QUEUE=database

################################################################################
# COURSE & LEARNING SETTINGS
################################################################################
COURSES_PAGINATION=15
LESSONS_PER_COURSE=10
ALLOW_GUEST_PREVIEW=true

################################################################################
# QUIZ SETTINGS
################################################################################
QUIZ_TIMEOUT_MINUTES=60
QUIZ_ATTEMPTS_ALLOWED=3
AI_QUIZ_GENERATION_ENABLED=true

################################################################################
# CERTIFICATE SETTINGS
################################################################################
CERTIFICATE_GENERATION_ENABLED=true
CERTIFICATE_STORAGE=local
