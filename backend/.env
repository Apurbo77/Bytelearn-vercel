################################################################################
# APPLICATION CONFIGURATION
################################################################################
APP_NAME=ByteLearn
APP_ENV=local
APP_KEY=base64:oKl95kC5DTu26Ug67K5l1b6PFmH+jw25PhzzSt3BvMI=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP Development Server Workers (uncomment if needed)
# PHP_CLI_SERVER_WORKERS=4

################################################################################
# SECURITY & ENCRYPTION
################################################################################
BCRYPT_ROUNDS=12

################################################################################
# LOGGING
################################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################################################################
# DATABASE
################################################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bytelearn
DB_USERNAME=root
DB_PASSWORD=

# SQLite alternative (uncomment to use SQLite instead of MySQL)
# DB_CONNECTION=sqlite
# DB_DATABASE=database.sqlite

################################################################################
# SESSION & AUTHENTICATION
################################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

################################################################################
# BROADCAST & REAL-TIME
################################################################################
BROADCAST_CONNECTION=log

################################################################################
# FILE STORAGE
################################################################################
FILESYSTEM_DISK=local

################################################################################
# QUEUE & JOBS
################################################################################
QUEUE_CONNECTION=database
# Alternative: QUEUE_CONNECTION=redis

################################################################################
# CACHING
################################################################################
CACHE_STORE=database
# CACHE_PREFIX=bytelearn_

################################################################################
# REDIS (Optional - for caching, sessions, queues)
################################################################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

################################################################################
# MEMCACHED (Optional - alternative cache driver)
################################################################################
MEMCACHED_HOST=127.0.0.1

################################################################################
# MAIL CONFIGURATION
################################################################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=rabbitebournewaste@gmail.com
MAIL_PASSWORD=tkrfjignsgblvnrb
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=rabbitebournewaste@gmail.com
MAIL_FROM_NAME=ByteLearn

# For local development, you can use 'log' to see emails in logs:
# MAIL_MAILER=log

################################################################################
# AWS S3 (Optional - for file storage)
################################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

################################################################################
# VITE (Frontend Build Tool)
################################################################################
VITE_APP_NAME=${APP_NAME}

